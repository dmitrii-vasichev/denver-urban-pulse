{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "data/pipeline/Dockerfile"
  },
  "deploy": {
    "startCommand": "python data/pipeline/run_daily.py",
    "cronSchedule": "0 6 * * *",
    "healthcheckPath": null,
    "restartPolicyType": "NEVER",
    "restartPolicyMaxRetries": 0
  }
}
